{
  "name": "gsd-autonomous-dev",
  "version": "5.0.0",
  "description": "GSD Autonomous Development Pipeline — Multi-Agent System with Vault Memory",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "pipeline": "ts-node src/index.ts pipeline run",
    "pipeline:dry": "ts-node src/index.ts pipeline run --dry-run",
    "evals": "ts-node src/evals/runner.ts",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && npm run evals"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.0",
    "docx": "^9.6.1",
    "playwright": "^1.59.1",
    "proper-lockfile": "^4.1.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/uuid": "^9.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
