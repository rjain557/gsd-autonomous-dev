{
    "version":  "4.1.0",
    "description":  "Central registry for all LLM agents. 3 subscription CLIs (Claude Max + ChatGPT Max + Gemini Ultra = $0 marginal cost) + 2 cheap API fallbacks.",
    "agents":  {
                   "claude":  {
                                  "type":  "cli",
                                  "cli_cmd":  "claude",
                                  "role":  [
                                               "review",
                                               "plan",
                                               "synthesize",
                                               "execute"
                                           ],
                                  "subscription": "Claude Max ($100-200/mo)",
                                  "rate_limits":  {
                                      "rpm":  10,
                                      "tpm":  80000,
                                      "daily_requests":  5000,
                                      "context_window":  200000,
                                      "cooldown_minutes":  5,
                                      "notes":  "Max plan. 5-20x Pro limits. Rolling 5-hour window. Degrades to Sonnet on exhaustion."
                                  }
                              },
                   "codex":  {
                                 "type":  "cli",
                                 "cli_cmd":  "codex",
                                 "role":  [
                                              "execute",
                                              "review"
                                          ],
                                 "subscription": "ChatGPT Max ($200/mo)",
                                 "rate_limits":  {
                                     "rpm":  10,
                                     "tpm":  100000,
                                     "daily_requests":  5000,
                                     "context_window":  200000,
                                     "cooldown_minutes":  5,
                                     "notes":  "Max plan. Full-auto mode for execute. Effectively unlimited for GPT-4o. Soft throttle on o1-pro/o3."
                                 }
                             },
                   "gemini":  {
                                  "type":  "cli",
                                  "cli_cmd":  "gemini",
                                  "role":  [
                                               "research",
                                               "spec-fix",
                                               "review"
                                           ],
                                  "subscription": "Gemini Ultra ($20/mo via Google One AI Premium)",
                                  "rate_limits":  {
                                      "rpm":  15,
                                      "tpm":  1000000,
                                      "daily_requests":  1500,
                                      "context_window":  1000000,
                                      "cooldown_minutes":  5,
                                      "notes":  "Ultra plan. 1M context window. Highest throughput of all 3 subscription models. Best for bulk review and research."
                                  }
                              },
                   "kimi":  {
                                "type":  "cli",
                                "cli_cmd":  "kimi",
                                "api_key_env":  "KIMI_API_KEY",
                                "model_id":  "kimi-k2.6",
                                "role":  [
                                             "review",
                                             "research",
                                             "requirements"
                                         ],
                                "enabled":  false,
                                "disabled_reason": "Disabled in rotation pool. Reenable for parallel remediation: K2.6 spawns 300 sub-agents — useful for parallelising RemediationAgent across slices once SkillForge is live.",
                                "thinking_flag":  "--thinking",
                                "no_thinking_flag":  "--no-thinking",
                                "note":  "Kimi K2.6 (released 2026-04-20). 262K ctx, 300 sub-agents. Install: pip install kimi-cli. Auth: KIMI_API_KEY.",
                                "rate_limits":  {
                                    "rpm":  20,
                                    "tpm":  200000,
                                    "daily_requests":  2000,
                                    "context_window":  262144,
                                    "cooldown_minutes":  10,
                                    "notes":  "262K context (was 8K). $0.75/$3.50/M. International endpoint via Cloudflare CDN."
                                }
                            },
                   "deepseek":  {
                                    "type":  "openai-compat",
                                    "endpoint":  "https://api.deepseek.com/v1/chat/completions",
                                    "api_key_env":  "DEEPSEEK_API_KEY",
                                    "model_id":  "deepseek-chat",
                                    "max_tokens":  8192,
                                    "temperature":  0.3,
                                    "role":  [
                                                 "execute",
                                                 "review",
                                                 "research"
                                             ],
                                    "supports_tools":  true,
                                    "enabled":  true,
                                    "rate_limits":  {
                                        "rpm":  60,
                                        "tpm":  500000,
                                        "daily_requests":  10000,
                                        "context_window":  131072,
                                        "cooldown_minutes":  5,
                                        "notes":  "Very high RPM and cheap ($0.28/$0.42/M). V3.2: 128K context (was 64K). Excellent for bulk review chunks."
                                    }
                                },
                   "glm5":  {
                                "type":  "openai-compat",
                                "endpoint":  "https://api.z.ai/api/paas/v4/chat/completions",
                                "api_key_env":  "GLM_API_KEY",
                                "model_id":  "glm-4.7-flash",
                                "model_id_paid":  "glm-4.7",
                                "max_tokens":  8192,
                                "temperature":  0.3,
                                "role":  [
                                             "execute",
                                             "review",
                                             "research"
                                         ],
                                "supports_tools":  true,
                                "enabled":  false,
                                "disabled_reason": "Corporate firewall blocks endpoint. Use DeepSeek/MiniMax instead. Free tier (glm-4.7-flash) available if firewall resolved.",
                                "endpoint_note":  "International endpoint (api.z.ai). Get API key from z.ai. Requires firewall whitelist for 128.14.69.x",
                                "rate_limits":  {
                                    "rpm":  30,
                                    "tpm":  300000,
                                    "daily_requests":  5000,
                                    "context_window":  131072,
                                    "cooldown_minutes":  10,
                                    "notes":  "Moderate RPM ($1.00/$3.20/M). International endpoint may have latency."
                                }
                            },
                   "minimax":  {
                                   "type":  "openai-compat",
                                   "endpoint":  "https://api.minimax.io/v1/chat/completions",
                                   "api_key_env":  "MINIMAX_API_KEY",
                                   "model_id":  "MiniMax-M1",
                                   "max_tokens":  8192,
                                   "temperature":  0.3,
                                   "role":  [
                                                "execute",
                                                "review",
                                                "research"
                                            ],
                                   "supports_tools":  true,
                                   "enabled":  true,
                                   "rate_limits":  {
                                       "rpm":  30,
                                       "tpm":  300000,
                                       "daily_requests":  5000,
                                       "context_window":  1048576,
                                       "cooldown_minutes":  10,
                                       "notes":  "1M context (M1 upgrade from Text-01). $0.40/$2.20/M. Can now handle full codebase in single fallback call."
                                   }
                               }
               },
    "rotation_pool_default":  [
                                  "claude",
                                  "codex",
                                  "gemini",
                                  "deepseek",
                                  "minimax"
                              ],
    "disabled_agents": ["kimi", "glm5"],
    "v4_model_strategy": {
        "description": "5-model: 3 subscription CLI (Claude/Codex/Gemini=$60/mo fixed) + 2 cheap API (DeepSeek/MiniMax=variable)",
        "subscription_models": ["claude", "codex", "gemini"],
        "api_models": ["deepseek", "minimax"],
        "removed": {
            "kimi": "Redundant — higher cost than DeepSeek/MiniMax, no unique capability",
            "glm5": "Corporate firewall blocks endpoint, highest API cost"
        }
    }
}
