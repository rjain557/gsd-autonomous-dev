keys/
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# Runtime state (changes every iteration, not engine code)
.gsd/supervisor/agent-cooldowns.json
.gsd/agent-handoff/
.claude/scheduled_tasks.lock
bridge.log

# V6 runtime state (SQLite + worktrees + observability + per-run artifacts)
memory/state.db
memory/state.db-shm
memory/state.db-wal
memory/state.db.lock
memory/milestones/
memory/observability/
memory/sessions/
.gsd-worktrees/
forensics/
.v6-smoke/
.v6-e2e/
.v6-status-test/

# Temp/debug files (prevent root clutter)
test-*.ps1
fix-*.py
check-*.ps1
kill-*.ps1
restart-*.ps1
*-err.log
*-out.log
legacy-pipeline.log
legacy-restart-*.log

# Project artifacts (generated by agents into wrong dir)
db/
# NOTE: The V6 TypeScript harness lives in src/ — do not ignore it.
# If external projects generate src/ here, clean them manually
!src/

# Graphify knowledge graph output (regenerated per-machine)
graphify-out/

# SDLC phase artifacts (generated per-project run)
docs/sdlc/
docs/spec/

# External project repos (managed by GSD, not tracked here)
external/
.gitnexus
