{
  "version": "2.0.0",
  "strategy": "seven-model-optimized",
  "description": "Claude leads reasoning and synthesis. Codex is the primary write agent. Gemini handles research/spec-fix. Kimi, DeepSeek, GLM-5, and MiniMax expand read-heavy review, council, and fallback throughput.",
  "phases": {
    "code-review": {
      "agent": "claude-code",
      "estimated_output_tokens": "2000-5000",
      "reason": "Primary reviewer and health scorer. Partitioned review can expand coverage with other models when enabled.",
      "inputs": [
        "full repo scan",
        "requirements-matrix.json",
        "specs",
        "figma deliverables"
      ],
      "outputs": [
        "health-current.json",
        "requirements-matrix.json (status updates)",
        "drift-report.md",
        "review-current.md"
      ]
    },
    "create-phases": {
      "agent": "claude-code",
      "estimated_output_tokens": "3000-6000",
      "reason": "Primary architect for requirement decomposition. Council extraction can replace this with a 3-agent verified pass.",
      "inputs": [
        "docs\\ (SDLC specs Phase A-E)",
        "design\\figma\\v## (latest)",
        "existing codebase structure"
      ],
      "outputs": [
        "requirements-matrix.json (full build)",
        "phase dependency graph",
        "figma-mapping.md"
      ]
    },
    "research": {
      "agent": "gemini",
      "mode": "--approval-mode plan",
      "estimated_output_tokens": "5000-15000",
      "reason": "Primary deep-read researcher. Falls back to Codex or REST reviewer pool if unavailable.",
      "inputs": [
        "requirements-matrix.json",
        "specs",
        "figma designs",
        "existing code",
        "external references"
      ],
      "outputs": [
        "research-findings.md",
        "pattern-analysis.md",
        "dependency-map.json",
        "tech-decisions.md"
      ]
    },
    "spec-fix": {
      "agent": "gemini",
      "mode": "--yolo",
      "estimated_output_tokens": "2000-5000",
      "reason": "Primary spec conflict resolver with Codex fallback and council validation.",
      "inputs": [
        "spec-conflicts/conflicts-to-resolve.json",
        "spec-consistency-report.json",
        "docs/"
      ],
      "outputs": [
        "spec-conflicts/resolution-summary.md",
        "updated docs files"
      ]
    },
    "plan": {
      "agent": "claude-code",
      "estimated_output_tokens": "1500-4000",
      "reason": "Planner that prioritizes dependency-aware, artifact-traceable batches.",
      "inputs": [
        "requirements-matrix.json",
        "research findings",
        "drift-report.md"
      ],
      "outputs": [
        "queue-current.json",
        "current-assignment.md"
      ]
    },
    "execute": {
      "agent": "codex",
      "estimated_output_tokens": "15000-100000+",
      "reason": "Primary write agent for bulk code generation. Parallel execute can distribute bounded subtasks across the 7-model pool.",
      "inputs": [
        "current-assignment.md",
        "queue-current.json",
        "specs",
        "figma mapping",
        "phase standards"
      ],
      "outputs": [
        "source code files (created/modified)",
        "handoff-log.jsonl entry"
      ]
    }
  },
  "token_budget_summary": {
    "claude_code_per_iteration": "6500-15000 tokens (review + create-phases + plan + synthesis)",
    "codex_per_iteration": "15000-100000+ tokens (execute/build)",
    "gemini_per_iteration": "5000-15000 tokens (research + spec-fix + review fallback)",
    "rest_pool_usage": "Burst-only for council, partitioned review, and fallback read-heavy work",
    "optimization": "Core 3-model phase ownership with 4 additional providers for throughput, failover, and coverage."
  },
  "execute_parallel": {
    "enabled": true,
    "max_concurrent": 3,
    "agent_pool": [
      "codex",
      "claude",
      "gemini"
    ],
    "strategy": "round-robin",
    "fallback_to_sequential": true,
    "subtask_timeout_minutes": 30
  },
  "council": {
    "reviewers": [
      "codex",
      "gemini",
      "kimi",
      "deepseek",
      "glm5",
      "minimax"
    ],
    "chunking": {
      "enabled": true,
      "max_chunk_size": 25,
      "min_group_size": 5,
      "strategy": "auto",
      "cooldown_seconds": 5,
      "min_requirements_to_chunk": 30
    }
  }
}
